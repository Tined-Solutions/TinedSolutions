---
import { developers } from "../data/developers";
---

<section id="team" class="reveal-on-scroll px-6 pt-6 pb-24 md:pt-10 md:pb-32">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 max-w-xl">
      <h2 class="font-tanker text-4xl leading-none text-tined-blue sm:text-5xl">
        Un equipo chico, <br />
        <span class="text-elegance-gold">pero que rinde.</span>
      </h2>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        developers.map(({ name, role, bio, initials }) => (
          <article class="futuristic-card reveal-on-scroll border border-elegance-gold/35 p-6 transition-colors hover:border-elegance-gold">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded border border-elegance-gold text-lg font-tanker text-tined-blue">
              {initials}
            </div>
            <h3 class="font-tanker mb-1 text-2xl tracking-wide text-tined-blue">{name}</h3>
            <p class="mb-3 text-xs font-medium uppercase tracking-wider text-elegance-gold">
              {role}
            </p>
            <p class="text-sm leading-relaxed text-deep-gray">{bio}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
import { projects } from "../data/projects";
---

<section id="portfolio" class="border-t border-slate-800 py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 max-w-xl">
      <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-500">
        Trabajos
      </p>
      <h2 class="text-3xl font-light leading-snug text-slate-100 sm:text-4xl">
        Proyectos que hemos <br />
        <span class="font-semibold">construido.</span>
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        projects.map(({ title, description, tags, category }) => (
          <article class="group border border-slate-800 p-6 transition-colors hover:border-slate-600">
            <div class="mb-4 flex items-start justify-between">
              <h3 class="text-base font-semibold text-slate-100">{title}</h3>
              <span class="ml-4 shrink-0 rounded border border-slate-700 px-2 py-0.5 text-xs text-slate-500">
                {category}
              </span>
            </div>
            <p class="mb-5 text-sm leading-relaxed text-slate-500">{description}</p>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded bg-slate-800 px-2 py-1 text-xs text-slate-400">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

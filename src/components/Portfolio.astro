---
import { projects } from "../data/projects";
---

<section id="portfolio" class="reveal-on-scroll border-t border-elegance-gold/35 py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 max-w-xl">
      <p class="mb-3 text-xs font-medium uppercase tracking-widest text-elegance-gold">
        Trabajos
      </p>
      <h2 class="text-3xl font-light leading-snug text-tined-blue sm:text-4xl">
        Proyectos que hemos <br />
        <span class="font-semibold">construido.</span>
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        projects.map(({ title, description, tags, category }) => (
          <article class="futuristic-card group reveal-on-scroll border border-elegance-gold/35 p-6 transition-colors hover:border-elegance-gold">
            <div class="mb-4 flex items-start justify-between">
              <h3 class="text-base font-semibold text-tined-blue">{title}</h3>
              <span class="ml-4 shrink-0 rounded border border-elegance-gold px-2 py-0.5 text-xs text-deep-gray">
                {category}
              </span>
            </div>
            <p class="mb-5 text-sm leading-relaxed text-deep-gray">{description}</p>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded bg-tined-blue/10 px-2 py-1 text-xs text-tined-blue">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

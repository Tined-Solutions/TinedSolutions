---
const email = "tinedsolutions@gmail.com";
---

<section id="contact" class="border-t border-slate-800 py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-16 lg:grid-cols-2">
      <div>
        <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-500">
          Contacto
        </p>
        <h2 class="mb-6 text-3xl font-light leading-snug text-slate-100 sm:text-4xl">
          Hablemos de su <br />
          <span class="font-semibold">próximo proyecto.</span>
        </h2>
        <p class="mb-8 text-sm leading-relaxed text-slate-400">
          ¿Tiene una idea en mente? ¿Necesita escalar su producto? Estamos listos para escucharle y proponer la mejor solución.
        </p>

        <div class="flex flex-col gap-3">
          <p class="text-xs font-medium uppercase tracking-widest text-slate-600">
            Correo electrónico
          </p>
          <a
            href={`mailto:${email}`}
            class="text-sm text-slate-300 underline underline-offset-4 transition-colors hover:text-slate-100"
          >
            {email}
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        class="flex flex-col gap-5"
        novalidate
      >
        <div>
          <label for="name" class="mb-1.5 block text-xs font-medium uppercase tracking-wider text-slate-500">
            Nombre
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="Su nombre completo"
            class="w-full rounded border border-slate-700 bg-slate-900 px-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-colors focus:border-slate-500 focus:ring-0"
          />
        </div>

        <div>
          <label for="email" class="mb-1.5 block text-xs font-medium uppercase tracking-wider text-slate-500">
            Correo electrónico
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="su@correo.com"
            class="w-full rounded border border-slate-700 bg-slate-900 px-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-colors focus:border-slate-500 focus:ring-0"
          />
        </div>

        <div>
          <label for="subject" class="mb-1.5 block text-xs font-medium uppercase tracking-wider text-slate-500">
            Asunto
          </label>
          <input
            id="subject"
            name="subject"
            type="text"
            required
            placeholder="¿En qué podemos ayudarle?"
            class="w-full rounded border border-slate-700 bg-slate-900 px-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-colors focus:border-slate-500 focus:ring-0"
          />
        </div>

        <div>
          <label for="message" class="mb-1.5 block text-xs font-medium uppercase tracking-wider text-slate-500">
            Mensaje
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            placeholder="Cuéntenos sobre su proyecto..."
            class="w-full resize-none rounded border border-slate-700 bg-slate-900 px-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-colors focus:border-slate-500 focus:ring-0"
          ></textarea>
        </div>

        <div id="form-message" class="hidden rounded border px-4 py-3 text-sm" role="alert"></div>

        <button
          type="submit"
          id="submit-btn"
          class="flex items-center justify-center gap-2 rounded bg-slate-100 px-6 py-3 text-sm font-medium text-slate-900 transition-colors hover:bg-white disabled:cursor-not-allowed disabled:opacity-60"
        >
          <span id="submit-text">Enviar mensaje</span>
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitText = document.getElementById("submit-text") as HTMLSpanElement;
  const formMessage = document.getElementById("form-message") as HTMLDivElement;

  function showMessage(message: string, isSuccess: boolean): void {
    formMessage.textContent = message;
    formMessage.className = isSuccess
      ? "rounded border border-green-800 bg-green-950 px-4 py-3 text-sm text-green-300"
      : "rounded border border-red-800 bg-red-950 px-4 py-3 text-sm text-red-300";
    formMessage.removeAttribute("hidden");
    formMessage.classList.remove("hidden");
  }

  function setLoading(loading: boolean): void {
    submitBtn.disabled = loading;
    submitText.textContent = loading ? "Enviando..." : "Enviar mensaje";
  }

  form?.addEventListener("submit", async (event: Event) => {
    event.preventDefault();

    const name = (form.elements.namedItem("name") as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem("email") as HTMLInputElement).value.trim();
    const subject = (form.elements.namedItem("subject") as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem("message") as HTMLTextAreaElement).value.trim();

    if (!name || !email || !subject || !message) {
      showMessage("Por favor, complete todos los campos.", false);
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showMessage("Por favor, ingrese un correo electrónico válido.", false);
      return;
    }

    setLoading(true);
    formMessage.classList.add("hidden");

    // Simula envío del formulario (integrar con servicio de backend o API en producción)
    await new Promise<void>((resolve) => setTimeout(resolve, 1200));

    setLoading(false);
    showMessage(
      "¡Mensaje enviado correctamente! Nos pondremos en contacto pronto.",
      true
    );
    form.reset();
  });
</script>

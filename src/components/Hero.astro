<section class="reveal-on-scroll is-visible relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
  <div class="hero-float pointer-events-none absolute -left-10 top-28 h-52 w-52 rounded-full bg-tined-blue/12 blur-3xl"></div>
  <div class="hero-float pointer-events-none absolute -right-8 bottom-24 h-48 w-48 rounded-full bg-elegance-gold/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="mb-6 text-xs font-medium uppercase tracking-widest text-elegance-gold">
      Desarrollo de software
    </p>

    <h1 class="mb-6 text-5xl font-light leading-tight tracking-tight text-tined-blue sm:text-6xl lg:text-7xl">
      Código que <br />
      <em class="font-semibold not-italic text-elegance-gold">funciona</em> y <br />
      <em class="font-semibold not-italic text-elegance-gold">perdura</em>.
    </h1>

    <p class="mx-auto mb-10 max-w-xl text-base leading-relaxed text-deep-gray">
      Construimos soluciones digitales con precisión y claridad. Sin complejidad innecesaria, sin adornos superfluos. Solo software que resuelve problemas reales.
    </p>

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#portfolio"
        class="glow-button-primary rounded bg-tined-blue px-6 py-3 text-sm font-medium text-cream transition-colors hover:bg-tined-blue/90"
      >
        Ver nuestro trabajo
      </a>
      <a
        href="#contact"
        class="glow-button-secondary rounded border border-elegance-gold px-6 py-3 text-sm font-medium text-tined-blue transition-colors hover:bg-elegance-gold/10"
      >
        Contáctenos
      </a>
    </div>
  </div>
</section>

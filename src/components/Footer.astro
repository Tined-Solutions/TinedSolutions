---
const currentYear = new Date().getFullYear();
const email = "tinedsolutions@gmail.com";
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm font-semibold tracking-tight text-slate-300">
        Tined<span class="text-slate-500">Solutions</span>
      </p>

      <p class="text-xs text-slate-600">
        © {currentYear} Tined Solutions. Todos los derechos reservados.
      </p>

      <a
        href={`mailto:${email}`}
        class="text-xs text-slate-500 transition-colors hover:text-slate-300"
      >
        {email}
      </a>
    </div>
  </div>
</footer>

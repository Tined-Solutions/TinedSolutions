---
const currentYear = new Date().getFullYear();
const email = "tinedsolutions@gmail.com";
---

<footer class="reveal-on-scroll border-t border-elegance-gold/35 bg-tined-blue/95 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm font-semibold tracking-tight text-cream">
        Tined<span class="text-elegance-gold">Solutions</span>
      </p>

      <p class="text-xs text-cream/80">
        © {currentYear} Tined Solutions. Todos los derechos reservados.
      </p>

      <a
        href={`mailto:${email}`}
        class="glow-link text-xs text-elegance-gold transition-colors hover:text-cream"
      >
        {email}
      </a>
    </div>
  </div>
</footer>

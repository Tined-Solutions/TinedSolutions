---
import { processSteps } from "../data/processSteps";
---

<section id="proceso" class="reveal-on-scroll px-6 pt-6 pb-24 md:pt-10 md:pb-32">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 flex flex-col items-start lg:items-end lg:text-right">
      <p class="mb-3 text-xs font-medium uppercase tracking-widest text-elegance-gold">
        Cómo trabajamos
      </p>
      <h2 class="font-tanker text-4xl leading-none text-tined-blue sm:text-5xl">
        De la primera charla a tu <br />
        <span class="text-elegance-gold">proyecto online.</span>
      </h2>
      <p class="mt-4 text-lg text-deep-gray lg:max-w-2xl">
        Del primer mensaje a una solución real.
      </p>
    </div>

    <ol class="relative space-y-12 before:absolute before:top-0 before:left-2 md:before:left-1/2 before:h-full before:w-px before:-translate-x-1/2 before:rounded-full before:bg-elegance-gold/35">
      {
        processSteps.map(({ stepLabel, title, description, isFinal }, index) => (
          <li class="group relative grid gap-8 md:grid-cols-2">
            <span
              class:list={[
                "absolute left-2 md:left-1/2 top-2 size-4 -translate-x-1/2 shrink-0 rounded-full bg-tined-blue shadow-[0_0_15px_color-mix(in_srgb,var(--color-tined-blue)_50%,transparent)] z-10 transition-transform group-hover:scale-125",
                isFinal && "size-5 ring-4 ring-elegance-gold/40 bg-elegance-gold",
              ]}
            ></span>

            <div class:list={[
              "relative flex flex-col",
              index % 2 === 0 ? "md:text-right md:pr-12" : "md:order-last md:pl-12",
              "pl-12 md:pl-0"
            ]}>
              <div class="-mt-1.5 max-w-md w-full">
                <time class="text-sm font-bold uppercase tracking-widest text-elegance-gold">
                  {stepLabel}
                </time>

                <h3 class="font-tanker mt-2 text-2xl tracking-wide text-tined-blue sm:text-3xl">{title}</h3>

                <p class="mt-3 text-sm leading-relaxed text-deep-gray sm:text-base">{description}</p>
              </div>
            </div>
            <div aria-hidden="true" class="hidden md:block"></div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import WhyUs from "../components/WhyUs.astro";
import Team from "../components/Team.astro";
import Portfolio from "../components/Portfolio.astro";
import ProcessJourney from "../components/ProcessJourney.astro";
import Contact from "../components/Contact.astro";
import SectionSeparator from "../components/SectionSeparator";
---

<BaseLayout>
  <Hero />
  <SectionSeparator client:visible text="¿Qué nos hace únicos?" />
  <WhyUs />
  <SectionSeparator client:visible text="¿Quiénes están detrás?" />
  <Team />
  <SectionSeparator client:visible text="¿Qué logramos?" />
  <Portfolio />
  <SectionSeparator client:visible text="¿Cómo trabajamos?" />
  <ProcessJourney />
  <SectionSeparator client:visible text="¿Listo para dar el próximo salto?" />
  <Contact />
</BaseLayout>
